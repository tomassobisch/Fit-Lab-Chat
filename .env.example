# TJOffice - Variables de Entorno
# Copia este archivo como '.env' en este mismo directorio y coloca tus credenciales reales.

# 🔑 Clave de API de Google Gemini (Obtenla gratis en Google AI Studio: https://aistudio.google.com/)
VITE_GEMINI_API_KEY=tu_api_key_de_gemini_aqui

# ⚡ Configuración de Supabase (Opcional - Si quieres persistir datos y usar tiempo real)
VITE_SUPABASE_URL=https://tu_proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu_anonymous_key_de_supabase_aqui
